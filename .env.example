# =============================================================================
# Open Gaming Platform — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme        # used by Docker Compose to create the DB

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme           # used by Docker Compose and all apps

# ── JWT (identity-api) ────────────────────────────────────────────────────────
JWT_SECRET=changeme-use-long-random-string-in-production

# =============================================================================
# The variables below are set automatically by docker-compose.yml.
# Only set them manually when running apps outside Docker (e.g. pnpm dev).
# =============================================================================

# ── App-level DB config (set per app in docker-compose, or set here for local) ──
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ogp
# DB_USER=ogp_user
# DB_PASSWORD=changeme
# DB_SCHEMA=identity          # change per app: identity | wallet | gaming | trading | admin
# DB_SYNC=true                # true for local dev — creates tables automatically
# DB_LOGGING=true             # true for local dev — prints SQL to console

# ── App-level Redis config ────────────────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=changeme
# REDIS_DB=0
